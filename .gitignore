# Build outputs
[Bb]in/
[Oo]bj/
out/

# User-specific files
*.user
*.rsuser
*.suo
*.userosscache
*.sln.docstates

# Visual Studio / Rider / VS Code
.vs/
.idea/
.vscode/

# NuGet
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/

# Logs
*.log
logs/

# Test results
[Tt]est[Rr]esult*/
[Bb]enchmarkDotNet.Artifacts/

# ASP.NET Core / runtime-generated files
wwwroot/lib/

# Local config overrides (keep template appsettings*.json tracked)
appsettings.Local.json
appsettings.*.local.json

# OS-generated files
.DS_Store
Thumbs.db
desktop.ini

# Dotnet local tool cache
.dotnet/tools/.store/

# Local environment files
.env
.env.*

# ============================================
# Angular Frontend (.NET solution)
# ============================================

# Node dependencies - too large to commit, install via npm install
node_modules/

# Angular build output - compiled/minified code generated at build time
dist/
build/

# Angular cache directory - stores compiled metadata and optimization data
.angular/

# npm/yarn lock files - optional but recommended to commit one for reproducible installs
# Uncomment if you want to ignore lock files:
# package-lock.json
# yarn.lock

# IDE-specific Angular extensions (generated, not needed in repo)
.vscode/extensions.json
